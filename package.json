{
  "name": "tss-stack-template",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "setup": "./scripts/setup.ts",
    "dev": "./scripts/dev/index.ts",
    "e2e": "./scripts/e2e/index.ts",
    "lint": "sh -c 'concurrently \"npm run lint -w backend -- $*\" \"npm run lint -w frontend -- $*\"' --",
    "build:types": "npm run build:types -w backend && npm run build:types -w frontend",
    "prepare": "husky"
  },
  "devDependencies": {
    "@aws-sdk/client-route-53": "^3.700.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "playwright": "^1.58.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.21.0"
  }
}
